@{
    ViewBag.Title = "Inicio";
}

<div class="hero-section">
    <h1>Bienvenido a la plataforma actualizada de inducción</h1>
    <p class="lead">
        Sistema institucional de gestión de cursos de inducción para aspirantes.<br />
        Plataforma moderna y segura para el proceso educativo.
    </p>
    <div>
        <a href="@Url.Action("Login", "Account")" class="btn btn-primary btn-lg">
            Acceder al Sistema
        </a>
        <a href="#informacion" class="btn btn-outline-primary btn-lg">
            Más Información
        </a>
    </div>
</div>

<div class="row mb-5">
    <div class="col-lg-4 col-md-6 mb-4">
        <div class="card hover-lift">
            <div class="card-header bg-primary">
                <i class="fas fa-user-graduate"></i>
                Aspirantes
            </div>
            <div class="card-body">
                <p class="text-muted">
                    Acceso a cursos de inducción, materiales educativos y entrega de tareas asignadas.
                </p>
                <ul class="list-group list-group-flush mb-3">
                    <li class="list-group-item">
                        <i class="fas fa-book-open"></i>
                        Materias asignadas
                    </li>
                    <li class="list-group-item">
                        <i class="fas fa-file-upload"></i>
                        Entrega de tareas
                    </li>
                    <li class="list-group-item">
                        <i class="fas fa-chart-line"></i>
                        Seguimiento de progreso
                    </li>
                </ul>
                <a href="@Url.Action("Index", "Aspirante")" class="btn btn-primary d-block w-100">
                    Ir a Mis Cursos
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-4 col-md-6 mb-4">
        <div class="card hover-lift">
            <div class="card-header bg-success">
                <i class="fas fa-users-cog"></i>
                Coordinadores
            </div>
            <div class="card-body">
                <p class="text-muted">
                    Gestión de estudiantes, revisión de entregas y asignación de calificaciones.
                </p>
                <ul class="list-group list-group-flush mb-3">
                    <li class="list-group-item">
                        <i class="fas fa-users"></i>
                        Lista de alumnos
                    </li>
                    <li class="list-group-item">
                        <i class="fas fa-clipboard-check"></i>
                        Calificar tareas
                    </li>
                    <li class="list-group-item">
                        <i class="fas fa-upload"></i>
                        Carga masiva
                    </li>
                </ul>
                <a href="@Url.Action("Index", "Coordinador")" class="btn btn-success d-block w-100">
                    Panel de Coordinación
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-4 col-md-6 mb-4">
        <div class="card hover-lift">
            <div class="card-header bg-secondary">
                <i class="fas fa-cog"></i>
                Administradores
            </div>
            <div class="card-body">
                <p class="text-muted">
                    Administración de materias, usuarios y configuraciones del sistema.
                </p>
                <ul class="list-group list-group-flush mb-3">
                    <li class="list-group-item">
                        <i class="fas fa-book"></i>
                        Gestión de materias
                    </li>
                    <li class="list-group-item">
                        <i class="fas fa-user-cog"></i>
                        Gestión de usuarios
                    </li>
                    <li class="list-group-item">
                        <i class="fas fa-database"></i>
                        Configuración
                    </li>
                </ul>
                <a href="@Url.Action("Index", "Admin")" class="btn btn-secondary d-block w-100">
                    Panel de Administración
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row mb-5" id="informacion">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-info-circle"></i>
                Características del Sistema
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">
                                <i class="fas fa-check-circle"></i>
                                <strong>Gestión completa de cursos</strong>
                                <p class="mb-0 text-muted" style="font-size: 0.9rem; margin-left: 2rem;">
                                    Organización de materias por carrera y periodo
                                </p>
                            </li>
                            <li class="list-group-item">
                                <i class="fas fa-check-circle"></i>
                                <strong>Sistema de entrega y calificación</strong>
                                <p class="mb-0 text-muted" style="font-size: 0.9rem; margin-left: 2rem;">
                                    Entrega de archivos y retroalimentación directa
                                </p>
                            </li>
                            <li class="list-group-item">
                                <i class="fas fa-check-circle"></i>
                                <strong>Dashboard personalizado</strong>
                                <p class="mb-0 text-muted" style="font-size: 0.9rem; margin-left: 2rem;">
                                    Información relevante según rol de usuario
                                </p>
                            </li>
                            <li class="list-group-item">
                                <i class="fas fa-check-circle"></i>
                                <strong>Seguimiento en tiempo real</strong>
                                <p class="mb-0 text-muted" style="font-size: 0.9rem; margin-left: 2rem;">
                                    Monitoreo automático del progreso estudiantil
                                </p>
                            </li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">
                                <i class="fas fa-check-circle"></i>
                                <strong>Integración con CaptacionDB</strong>
                                <p class="mb-0 text-muted" style="font-size: 0.9rem; margin-left: 2rem;">
                                    Sincronización directa de datos institucionales
                                </p>
                            </li>
                            <li class="list-group-item">
                                <i class="fas fa-check-circle"></i>
                                <strong>Diseño responsive</strong>
                                <p class="mb-0 text-muted" style="font-size: 0.9rem; margin-left: 2rem;">
                                    Compatible con dispositivos móviles y tablets
                                </p>
                            </li>
                            <li class="list-group-item">
                                <i class="fas fa-check-circle"></i>
                                <strong>Arquitectura segura</strong>
                                <p class="mb-0 text-muted" style="font-size: 0.9rem; margin-left: 2rem;">
                                    ASP.NET MVC con autenticación robusta
                                </p>
                            </li>
                            <li class="list-group-item">
                                <i class="fas fa-check-circle"></i>
                                <strong>Interfaz institucional</strong>
                                <p class="mb-0 text-muted" style="font-size: 0.9rem; margin-left: 2rem;">
                                    Diseño profesional y minimalista
                                </p>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card" style="background-color: var(--gray-50); border: 1px dashed var(--gray-300);">
            <div class="card-body text-center">
                <h5 class="text-muted">
                    <i class="fas fa-code"></i>
                    Información Técnica
                </h5>
                <p class="mb-2 text-muted">
                    <strong>Tecnología:</strong> ASP.NET MVC 5 (.NET Framework 4.7.2) | Entity Framework 6.x | SQL Server
                </p>
                <p class="mb-2 text-muted">
                    <strong>Base de Datos:</strong> CaptacionDB con tablas Ind_Materias, Ind_Unidades, Ind_Materiales, Ind_ProgresoAspirantes
                </p>
                <p class="mb-0 text-muted">
                    <strong>Roles:</strong> Administrador | Director | Coordinador | Aspirante
                </p>
            </div>
        </div>
    </div>
</div>