@model induccion_refactorization.ViewModels.LoginViewModel
@{
    ViewBag.Title = "Iniciar Sesi&oacute;n";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header text-center bg-white border-bottom">
                <i class="fas fa-sign-in-alt text-primary mb-2" style="font-size: 2rem;"></i>
                <h4 class="mb-0">Iniciar Sesi&oacute;n</h4>
            </div>
            <div class="card-body p-4">
                <p class="text-center text-muted mb-4">
                    Ingrese sus credenciales para acceder al sistema
                </p>

                @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "login-form", role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                    <div class="form-group mb-3">
                        @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-envelope text-muted"></i>
                            </span>
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "correo@ejemplo.com", autocomplete = "email", required = "required" })
                        </div>
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                    </div>

                    <div class="form-group mb-3">
                        @Html.LabelFor(m => m.Password, "Contraseña", new { @class = "form-label" })
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-lock text-muted"></i>
                            </span>
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Ingresa tu contraseña", autocomplete = "current-password", required = "required" })
                        </div>
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                    </div>

                    <div class="form-group mb-4">
                        <div class="form-check">
                            @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input", id = "rememberMe" })
                            <label class="form-check-label" for="rememberMe">
                                Recordarme en este dispositivo
                            </label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="fas fa-sign-in-alt me-2"></i>
                        Acceder al Sistema
                    </button>
                }

                <hr class="my-4" />

                <div class="text-center">
                    <small class="text-muted">
                        <i class="fas fa-info-circle"></i>
                        Si olvid&oacute; su contrase&ntilde;a, contacte al administrador del sistema
                </small>
                </div>
            </div>
        </div>

        <div class="text-center mt-4">
            <a href="@Url.Action("Index", "Home")" class="btn btn-link text-decoration-none">
                <i class="fas fa-arrow-left"></i>
                Volver a Inicio
            </a>
        </div>
    </div>
</div>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
    
    <script>
        $(document).ready(function() {
            // Auto-focus on email input
            $('#Email').focus();

            // Handle form submission with loading state
            $('.login-form').on('submit', function() {
                var $btn = $(this).find('button[type="submit"]');
                $btn.prop('disabled', true);
                $btn.html('<i class="fas fa-spinner fa-spin me-2"></i> Verificando credenciales...');
            });
        });
    </script>

    <style>
        /* Pristine Login Form Styles - UTTN Institutional Theme */
        .card {
            border-radius: 8px;
            border: 1px solid #dee2e6;
        }

        .card-header {
            border-radius: 8px 8px 0 0;
        }

        .input-group-text {
            border-right: 0;
            min-width: 45px;
            justify-content: center;
        }

        .input-group .form-control {
            border-left: 0;
        }

        .input-group .form-control:focus {
            border-color: #1ab192;
            box-shadow: 0 0 0 0.2rem rgba(26, 177, 146, 0.15);
        }

        .input-group:focus-within .input-group-text {
            border-color: #1ab192;
            background-color: #e8f7f3;
        }

        .form-check-input:checked {
            background-color: #1ab192;
            border-color: #1ab192;
        }

        .btn-primary {
            background-color: #1ab192;
            border-color: #1ab192;
            font-weight: 500;
            padding: 0.75rem;
            transition: all 0.3s ease;
        }

        .btn-primary:hover,
        .btn-primary:focus {
            background-color: #159078;
            border-color: #159078;
            box-shadow: 0 4px 12px rgba(26, 177, 146, 0.3);
            transform: translateY(-1px);
        }

        .btn-primary:disabled {
            background-color: #6c757d;
            border-color: #6c757d;
        }

        .form-label {
            font-weight: 500;
            color: #495057;
            margin-bottom: 0.5rem;
        }

        .form-control {
            border-radius: 4px;
            padding: 0.65rem 0.75rem;
        }

        .input-group-text {
            border-radius: 4px 0 0 4px;
        }

        .input-group .form-control {
            border-radius: 0 4px 4px 0;
        }

        .shadow-sm {
            box-shadow: 0 0.125rem 0.5rem rgba(0, 0, 0, 0.075) !important;
        }

        @@media (max-width: 576px) {
            .col-md-5 {
                padding: 0 1rem;
            }

            .card-body {
                padding: 1.5rem !important;
            }
        }

        .btn-primary {
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .validation-summary-errors {
            background-color: #f8d7da;
            border: 1px solid #f5c6cb;
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1rem;
        }

        .validation-summary-errors ul {
            margin-bottom: 0;
            list-style: none;
            padding-left: 0;
        }

        .validation-summary-errors li {
            color: #721c24;
        }
    </style>
}
