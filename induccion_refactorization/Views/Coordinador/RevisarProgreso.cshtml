@model IEnumerable<induccion_refactorization.Models.Ind_ProgresoAspirante>
@{
    ViewBag.Title = "Revisar Progreso de Unidades";
}

<div class="mb-4">
    <a href="@Url.Action("Index", "Coordinador")" class="btn btn-link ps-0">
        <i class="fas fa-arrow-left"></i> Volver al Panel
    </a>
    <h2 class="mb-1"><i class="fas fa-list-check text-primary"></i> Unidades Entregadas por Revisar</h2>
    <p class="text-muted mb-0">Bienvenido, <strong>@ViewBag.NombreCompleto</strong></p>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Unidades (@Model.Count())</h5>
    </div>
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover table-clean mb-0">
                    <thead>
                        <tr>
                            <th>Aspirante</th>
                            <th>Materia</th>
                            <th>Unidad</th>
                            <th>Fecha de Entrega</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var progreso in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="icon-badge icon-badge-sm icon-badge-primary">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <span>@(progreso.Aspirante?.Usuario?.NombreCompleto)</span>
                                    </div>
                                </td>
                                <td>@(progreso.Ind_Unidad?.Ind_Materia?.Nombre)</td>
                                <td>@(progreso.Ind_Unidad?.Nombre)</td>
                                <td>@(progreso.FechaEnvio?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</td>
                                <td class="text-end">
                                    <a href="@Url.Action("CalificarProgreso", new { id = progreso.ProgresoID })"
                                       class="btn btn-sm btn-primary" title="Calificar">
                                        <i class="fas fa-star"></i> Calificar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="icon-badge icon-badge-lg icon-badge-success">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="empty-state-title">Todo al día</div>
                <p class="mb-0">No hay unidades pendientes de revisión.</p>
            </div>
        }
    </div>
</div>
