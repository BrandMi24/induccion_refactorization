@model induccion_refactorization.ViewModels.PagedResult<induccion_refactorization.Models.Ind_ProgresoAspirante>
@{
    ViewBag.Title = "Revisar Progreso de Unidades";
}

<div class="mb-4">
    <a href="@Url.Action("Index", "Coordinador")" class="btn btn-link ps-0">
        <i class="fas fa-arrow-left"></i> Volver al Panel
    </a>
    <h2 class="mb-1"><i class="fas fa-list-check text-primary"></i> Unidades Entregadas por Revisar</h2>
    <p class="text-muted mb-0">Bienvenido, <strong>@ViewBag.NombreCompleto</strong></p>
</div>

<div class="card mb-3">
    <div class="card-body py-3">
        @using (Html.BeginForm("RevisarProgreso", "Coordinador", FormMethod.Get))
        {
            <div class="row g-2 align-items-end">
                <div class="col-md-6">
                    <label class="form-label small text-muted mb-1">Buscar</label>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm"
                           placeholder="Aspirante o unidad..." />
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-muted mb-1">Materia</label>
                    @Html.DropDownList("materiaId", (SelectList)ViewBag.MateriasFiltro, "Todas las materias", new { @class = "form-select form-select-sm" })
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-primary flex-grow-1">
                        <i class="fas fa-search"></i> Filtrar
                    </button>
                    <a href="@Url.Action("RevisarProgreso", "Coordinador")" class="btn btn-sm btn-outline-secondary btn-icon" title="Limpiar filtros">
                        <i class="fas fa-times"></i>
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="mb-0">Unidades</h5>
        <small class="text-muted">@Model.TotalCount resultado(s)</small>
    </div>
    <div class="card-body p-0">
        @if (Model.Items.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover table-clean mb-0">
                    <thead>
                        <tr>
                            @{
                                var sortRouteValues = new System.Web.Routing.RouteValueDictionary(new
                                {
                                    search = ViewBag.Search,
                                    materiaId = ViewBag.MateriaId
                                });
                            }
                            <th>
                                @Html.Partial("_SortableHeader", new induccion_refactorization.ViewModels.SortableHeaderViewModel
                                {
                                    Label = "Aspirante", SortField = "Aspirante", CurrentSortBy = ViewBag.SortBy, CurrentSortDir = ViewBag.SortDir,
                                    Action = "RevisarProgreso", Controller = "Coordinador", RouteValues = sortRouteValues
                                })
                            </th>
                            <th>
                                @Html.Partial("_SortableHeader", new induccion_refactorization.ViewModels.SortableHeaderViewModel
                                {
                                    Label = "Materia", SortField = "Materia", CurrentSortBy = ViewBag.SortBy, CurrentSortDir = ViewBag.SortDir,
                                    Action = "RevisarProgreso", Controller = "Coordinador", RouteValues = sortRouteValues
                                })
                            </th>
                            <th>
                                @Html.Partial("_SortableHeader", new induccion_refactorization.ViewModels.SortableHeaderViewModel
                                {
                                    Label = "Unidad", SortField = "Unidad", CurrentSortBy = ViewBag.SortBy, CurrentSortDir = ViewBag.SortDir,
                                    Action = "RevisarProgreso", Controller = "Coordinador", RouteValues = sortRouteValues
                                })
                            </th>
                            <th>
                                @Html.Partial("_SortableHeader", new induccion_refactorization.ViewModels.SortableHeaderViewModel
                                {
                                    Label = "Fecha de Entrega", SortField = "Fecha", CurrentSortBy = ViewBag.SortBy, CurrentSortDir = ViewBag.SortDir,
                                    Action = "RevisarProgreso", Controller = "Coordinador", RouteValues = sortRouteValues
                                })
                            </th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var progreso in Model.Items)
                        {
                            <tr>
                                <td data-label="Aspirante">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="icon-badge icon-badge-sm icon-badge-primary">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <span>@(progreso.Aspirante?.Usuario?.NombreCompleto)</span>
                                    </div>
                                </td>
                                <td data-label="Materia">@(progreso.Ind_Unidad?.Ind_Materia?.Nombre)</td>
                                <td data-label="Unidad">@(progreso.Ind_Unidad?.Nombre)</td>
                                <td data-label="Fecha de Entrega">@(progreso.FechaEnvio?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</td>
                                <td class="text-end" data-label="Acciones">
                                    <a href="@Url.Action("CalificarProgreso", new { id = progreso.ProgresoID })"
                                       class="btn btn-sm btn-primary" title="Calificar">
                                        <i class="fas fa-star"></i> Calificar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @Html.Partial("_Pager", new induccion_refactorization.ViewModels.PagerViewModel
            {
                PageNumber = Model.PageNumber,
                TotalPages = Model.TotalPages,
                PageSize = Model.PageSize,
                Action = "RevisarProgreso",
                Controller = "Coordinador",
                RouteValues = new System.Web.Routing.RouteValueDictionary(new { search = ViewBag.Search, materiaId = ViewBag.MateriaId, sortBy = ViewBag.SortBy, sortDir = ViewBag.SortDir })
            })
        }
        else
        {
            <div class="empty-state">
                <div class="icon-badge icon-badge-lg icon-badge-success">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="empty-state-title">Todo al día</div>
                <p class="mb-0">No hay unidades pendientes de revisión.</p>
            </div>
        }
    </div>
</div>
