@model induccion_refactorization.Models.Ind_Materia
@{
    ViewBag.Title = "Contenido de la Materia";
    var progresoRecords = ViewBag.ProgresoRecords as List<induccion_refactorization.Models.Ind_ProgresoAspirante>;
    var submisiones = ViewBag.Submisiones as List<induccion_refactorization.Models.Ind_Submision>;
}

<div class="mb-3">
    <a href="@Url.Action("Index", "Aspirante")" class="btn btn-link ps-0">
        <i class="fas fa-arrow-left"></i> Volver a Mis Cursos
    </a>
</div>

<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="fas fa-book-open"></i> @ViewBag.MateriaNombre</h5>
    </div>
    <div class="card-body">
        <p class="text-muted mb-3">@ViewBag.MateriaDescripcion</p>

        @if (Model.Ind_Unidades != null && Model.Ind_Unidades.Any())
        {
            var totalUnidades = Model.Ind_Unidades.Count;
            var unidadesCompletadas = progresoRecords?.Count(p => p.Estado == "Calificado") ?? 0;
            var porcentajeTotal = totalUnidades > 0 ? (int)((unidadesCompletadas * 100.0) / totalUnidades) : 0;

            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="small fw-semibold">Progreso General</span>
                <span class="small text-muted">@unidadesCompletadas de @totalUnidades unidades</span>
            </div>
            <div class="progress" style="height: 10px;">
                <div class="progress-bar" role="progressbar" style="width: @porcentajeTotal%;"
                     aria-valuenow="@porcentajeTotal" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
        }
    </div>
</div>

@if (Model.Ind_Unidades != null && Model.Ind_Unidades.Any())
{
    var unidadesOrdenadas = Model.Ind_Unidades.OrderBy(u => u.Orden).ToList();

    foreach (var unidad in unidadesOrdenadas)
    {
        var progreso = progresoRecords?.FirstOrDefault(p => p.UnidadID == unidad.UnidadID);
        var estadoClass = "secondary";
        var estadoTexto = "Pendiente";
        var estadoIcon = "fa-circle";

        if (progreso != null)
        {
            switch (progreso.Estado)
            {
                case "Asignado":
                    estadoClass = "info";
                    estadoTexto = "Asignado";
                    estadoIcon = "fa-tasks";
                    break;
                case "Entregado":
                    estadoClass = "warning";
                    estadoTexto = "Entregado";
                    estadoIcon = "fa-check";
                    break;
                case "Calificado":
                    estadoClass = "success";
                    estadoTexto = $"Calificado - {progreso.Calificacion:F2}";
                    estadoIcon = "fa-star";
                    break;
            }
        }

        <div class="card mb-3 unidad-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">
                    <i class="fas fa-list-ol"></i>
                    Unidad @unidad.Orden: @unidad.Nombre
                </h6>
                <span class="badge bg-@estadoClass">
                    <i class="fas @estadoIcon"></i> @estadoTexto
                </span>
            </div>
            <div class="card-body">
                @if (unidad.Ind_Materiales != null && unidad.Ind_Materiales.Any())
                {
                    <h6 class="small text-muted text-uppercase mb-2">Materiales de Aprendizaje</h6>
                    <ul class="list-group list-group-flush mb-3">
                        @foreach (var material in unidad.Ind_Materiales)
                        {
                            var iconClass = "";
                            var badgeColor = "";

                            switch (material.TipoRecurso?.ToLower())
                            {
                                case "pdf":
                                    iconClass = "fa-file-pdf";
                                    badgeColor = "bg-danger";
                                    break;
                                case "video":
                                    iconClass = "fa-video";
                                    badgeColor = "bg-primary";
                                    break;
                                case "enlace":
                                    iconClass = "fa-link";
                                    badgeColor = "bg-info";
                                    break;
                                default:
                                    iconClass = "fa-file";
                                    badgeColor = "bg-secondary";
                                    break;
                            }

                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <div>
                                    <i class="fas @iconClass text-muted me-1"></i>
                                    @material.Nombre
                                </div>
                                <div>
                                    <span class="badge @badgeColor me-2">@material.TipoRecurso</span>
                                    <a href="@material.RutaURL" target="_blank" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-external-link-alt"></i> Abrir
                                    </a>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted small"><i class="fas fa-info-circle"></i> No hay materiales disponibles para esta unidad.</p>
                }

                @{
                    var entregablesActivos = unidad.Ind_Entregables?.Where(e => e.Activo).ToList();
                }
                @if (entregablesActivos != null && entregablesActivos.Any())
                {
                    <h6 class="small text-muted text-uppercase mb-2 mt-3">Entregables</h6>
                    <ul class="list-group list-group-flush mb-3">
                        @foreach (var entregable in entregablesActivos)
                        {
                            var submision = submisiones?.FirstOrDefault(s => s.EntregableID == entregable.EntregableID);
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <div>
                                    <i class="fas fa-file-alt text-muted me-1"></i>
                                    @entregable.Titulo
                                    @if (entregable.FechaLimite.HasValue)
                                    {
                                        <small class="text-muted"> (límite: @entregable.FechaLimite.Value.ToString("dd/MM/yyyy"))</small>
                                    }
                                </div>
                                <div>
                                    @if (submision == null)
                                    {
                                        <span class="badge bg-secondary me-2">Sin enviar</span>
                                    }
                                    else
                                    {
                                        var badgeClass = submision.Estado == "Revisado" ? "bg-success"
                                            : submision.Estado == "Rechazado" ? "bg-danger" : "bg-warning";
                                        <span class="badge @badgeClass me-2">
                                            @submision.Estado
                                            @if (submision.Calificacion.HasValue)
                                            {
                                                @: - @submision.Calificacion.Value.ToString("F2")
                                            }
                                        </span>
                                    }
                                    <a href="@Url.Action("UploadEntregable", "Aspirante", new { id = entregable.EntregableID })"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-upload"></i> @(submision == null ? "Subir" : "Reemplazar")
                                    </a>
                                </div>
                            </li>
                        }
                    </ul>
                }

                @if (progreso != null)
                {
                    <hr />
                    <div class="small">
                        <p class="mb-1 text-muted">
                            <strong class="text-body">Fecha de Asignación:</strong>
                            @progreso.FechaAsignacion.ToString("dd/MM/yyyy")
                        </p>

                        @if (progreso.FechaEnvio.HasValue)
                        {
                            <p class="mb-1 text-muted">
                                <strong class="text-body">Fecha de Entrega:</strong> @progreso.FechaEnvio.Value.ToString("dd/MM/yyyy")
                            </p>
                        }

                        @if (!string.IsNullOrEmpty(progreso.ComentariosEvaluador))
                        {
                            <p class="mb-1 text-muted">
                                <strong class="text-body">Comentarios del Evaluador:</strong>
                                <br />
                                <em>@progreso.ComentariosEvaluador</em>
                            </p>
                        }

                        @if (progreso.Estado == "Calificado")
                        {
                            <div class="alert alert-success mb-0 mt-2 py-2">
                                <i class="fas fa-check-circle"></i>
                                <strong>Unidad Completada</strong> — Calificación: <strong>@progreso.Calificacion.Value.ToString("F2")</strong>
                            </div>
                        }
                        else if (progreso.Estado == "Asignado")
                        {
                            <div class="mt-2">
                                @using (Html.BeginForm("MarcarEntregado", "Aspirante", new { progresoId = progreso.ProgresoID, materiaId = Model.MateriaID }, FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-primary"
                                            onclick="return confirm('¿Marcar esta unidad como entregada? Tu coordinador la revisará.');">
                                        <i class="fas fa-check"></i> Marcar como Entregado
                                    </button>
                                }
                            </div>
                        }
                        else if (progreso.Estado == "Entregado")
                        {
                            <div class="alert alert-warning mb-0 mt-2 py-2">
                                <i class="fas fa-hourglass-half"></i>
                                En revisión por el coordinador.
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
}
else
{
    <div class="empty-state">
        <div class="icon-badge icon-badge-lg icon-badge-warning">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        <div class="empty-state-title">Sin unidades configuradas</div>
        <p class="mb-0">Esta materia no tiene unidades disponibles aún.</p>
    </div>
}

@section styles {
    <style>
        .unidad-card {
            border-left: 3px solid var(--primary-color);
            transition: box-shadow var(--transition-base);
        }

        .unidad-card:hover {
            box-shadow: var(--shadow-sm);
        }

        .list-group-item {
            border-left: none;
            border-right: none;
        }

        .list-group-item:first-child {
            border-top: none;
        }

        .progress-bar {
            background-color: var(--primary-color);
        }
    </style>
}
