@model induccion_refactorization.Models.Ind_Materia
@{
    ViewBag.Title = "Editar Materia";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0"><i class="fas fa-edit"></i> Editar Materia de Inducción</h4>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("EditMateria", "InductionMaintenance", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.MateriaID)
                        @Html.HiddenFor(model => model.Activo)

                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="form-group">
                            @Html.LabelFor(model => model.Nombre, new { @class = "control-label" })
                            @Html.TextBoxFor(model => model.Nombre, new { @class = "form-control" })
                            @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            @Html.LabelFor(model => model.Descripcion, new { @class = "control-label" })
                            @Html.TextAreaFor(model => model.Descripcion, new { @class = "form-control", rows = 4 })
                            @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "text-danger" })
                        </div>

                        var selectedCarreraIds = (int[])ViewBag.SelectedCarreraIds;
                        <div class="form-group">
                            <label class="control-label">Carreras</label>
                            <div class="form-check mb-2">
                                <input type="checkbox" class="form-check-input" id="todasLasCarreras" name="todasLasCarreras" value="true" @(Model.TodasLasCarreras ? "checked=\"checked\"" : "") />
                                <label class="form-check-label" for="todasLasCarreras"><strong>Visible para todas las carreras</strong></label>
                            </div>
                            <div id="carrerasListContainer" class="row g-2 ps-2">
                                @foreach (var carrera in (List<induccion_refactorization.Models.Carrera>)ViewBag.CarrerasList)
                                {
                                    var isChecked = selectedCarreraIds.Contains(carrera.CarreraID);
                                    <div class="col-md-6">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input carrera-checkbox" name="carreraIds" value="@carrera.CarreraID" id="carrera_@carrera.CarreraID" @(isChecked ? "checked=\"checked\"" : "") />
                                            <label class="form-check-label" for="carrera_@carrera.CarreraID">@carrera.Nombre</label>
                                        </div>
                                    </div>
                                }
                            </div>
                            <small class="form-text text-muted">Selecciona una o más carreras, o marca la casilla de arriba para hacerla visible a todas</small>
                        </div>

                        <div class="form-group">
                            @Html.LabelFor(model => model.PeriodoID, "Periodo", new { @class = "control-label" })
                            @Html.DropDownList("PeriodoID", (SelectList)ViewBag.PeriodoID, new { @class = "form-control" })
                            @Html.ValidationMessageFor(model => model.PeriodoID, "", new { @class = "text-danger" })
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Guardar Cambios
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
        $(document).ready(function () {
            function toggleCarrerasList() {
                var todas = $('#todasLasCarreras').is(':checked');
                $('.carrera-checkbox').prop('disabled', todas);
                $('#carrerasListContainer').css('opacity', todas ? 0.5 : 1);
            }
            $('#todasLasCarreras').on('change', toggleCarrerasList);
            toggleCarrerasList();
        });
    </script>
}
