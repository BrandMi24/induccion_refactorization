@model induccion_refactorization.Models.Ind_Entregable
@{
    ViewBag.Title = "Crear Entregable";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0"><i class="fas fa-file-upload"></i> Crear Entregable</h4>
                    <small class="text-muted">
                        Materia: @ViewBag.MateriaNombre | Unidad: @ViewBag.UnidadNombre
                    </small>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("CreateEntregable", "InductionMaintenance", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.UnidadID)

                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="form-group">
                            @Html.LabelFor(model => model.Titulo, new { @class = "control-label" })
                            @Html.TextBoxFor(model => model.Titulo, new { @class = "form-control", placeholder = "Ej: Ensayo sobre valores institucionales" })
                            @Html.ValidationMessageFor(model => model.Titulo, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            @Html.LabelFor(model => model.Instrucciones, new { @class = "control-label" })
                            @Html.TextAreaFor(model => model.Instrucciones, new { @class = "form-control", rows = 4, placeholder = "Describe qué debe entregar el aspirante..." })
                            @Html.ValidationMessageFor(model => model.Instrucciones, "", new { @class = "text-danger" })
                        </div>

                        <div class="row">
                            <div class="col-md-6 form-group">
                                @Html.LabelFor(model => model.FechaLimite, "Fecha Límite", new { @class = "control-label" })
                                @Html.TextBoxFor(model => model.FechaLimite, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                @Html.ValidationMessageFor(model => model.FechaLimite, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-6 form-group">
                                @Html.LabelFor(model => model.PonderacionMax, "Ponderación Máxima", new { @class = "control-label" })
                                @Html.TextBoxFor(model => model.PonderacionMax, new { @class = "form-control", type = "number", step = "0.01", min = "0", max = "100" })
                                @Html.ValidationMessageFor(model => model.PonderacionMax, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("ManageUnidades", new { id = ViewBag.MateriaID })" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Guardar Entregable
                            </button>
                        </div>
                    }
                </div>
            </div>

            <div class="alert alert-info mt-3">
                <i class="fas fa-info-circle"></i>
                <strong>Nota:</strong> Los aspirantes podrán subir un archivo (PDF, DOCX, XLSX, JPG o PNG, máximo 10 MB) para este entregable desde su panel de cursos.
            </div>
        </div>
    </div>
</div>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
