@{
    ViewBag.Title = "Acceso Denegado";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card" style="border-left: 4px solid var(--danger);">
            <div class="card-body text-center">
                <i class="fas fa-exclamation-triangle" style="font-size: 4rem; color: var(--danger); margin-bottom: 1.5rem;"></i>
                
                <h2 style="color: var(--danger); margin-bottom: 1rem;">Acceso Denegado</h2>
                
                <p class="lead" style="color: var(--gray-700);">
                    @(ViewBag.Message ?? "No tiene permisos para acceder a esta sección del sistema.")
                </p>
                
                <hr class="my-4" />
                
                <p class="text-muted">
                    Esta área está restringida para usuarios con permisos específicos.<br />
                    Si cree que esto es un error, contacte al administrador del sistema.
                </p>
                
                <div class="mt-4">
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
                        <i class="fas fa-home"></i>
                        Volver a Inicio
                    </a>
                    
                    @if (Request.IsAuthenticated)
                    {
                        using (Html.BeginForm("Logout", "Account", FormMethod.Post, new { @style = "display: inline;" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-secondary">
                                <i class="fas fa-sign-out-alt"></i>
                                Cerrar Sesión
                            </button>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
