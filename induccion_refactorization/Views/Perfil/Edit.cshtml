@model induccion_refactorization.Models.Usuario
@{
    ViewBag.Title = "Editar Perfil";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="mb-3">
            <a href="@Url.Action("Index", "Perfil")" class="btn btn-link ps-0">
                <i class="fas fa-arrow-left"></i> Volver a Mi Perfil
            </a>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-user-edit"></i> Editar Perfil</h5>
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Edit", "Perfil", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" name="nombre" class="form-control" value="@Model.Nombre" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Apellido Paterno</label>
                            <input type="text" name="apellidoPaterno" class="form-control" value="@Model.ApellidoPaterno" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Apellido Materno</label>
                            <input type="text" name="apellidoMaterno" class="form-control" value="@Model.ApellidoMaterno" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Teléfono</label>
                        <input type="text" name="telefono" class="form-control" value="@Model.Telefono" maxlength="10" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted">Correo electrónico</label>
                        <input type="email" class="form-control" value="@Model.CorreoElectronico" disabled />
                        <small class="text-muted">Contacta al administrador para cambiar tu correo.</small>
                    </div>

                    <hr />

                    <div class="mb-3">
                        <label class="form-label">Nueva Contraseña</label>
                        <input type="password" name="nuevaContrasena" class="form-control" placeholder="Dejar en blanco para no cambiar" />
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a href="@Url.Action("Index", "Perfil")" class="btn btn-outline-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Guardar Cambios
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
