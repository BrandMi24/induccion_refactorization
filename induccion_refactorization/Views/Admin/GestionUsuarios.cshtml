@model induccion_refactorization.ViewModels.PagedResult<induccion_refactorization.Models.Usuario>
@{
    ViewBag.Title = "Gestión de Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1"><i class="fas fa-user-cog text-primary"></i> Gestión de Usuarios</h2>
        <p class="text-muted mb-0">Bienvenido, <strong>@ViewBag.NombreCompleto</strong></p>
    </div>
    <a href="@Url.Action("CreateUsuario", "Admin")" class="btn btn-primary">
        <i class="fas fa-user-plus"></i> Nuevo Usuario
    </a>
</div>

<div class="card mb-3">
    <div class="card-body py-3">
        @using (Html.BeginForm("GestionUsuarios", "Admin", FormMethod.Get))
        {
            <div class="row g-2 align-items-end">
                <div class="col-md-5">
                    <label class="form-label small text-muted mb-1">Buscar</label>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm"
                           placeholder="Nombre, usuario o correo..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">Rol</label>
                    @Html.DropDownList("rolId", (SelectList)ViewBag.RolesFiltro, "Todos los roles", new { @class = "form-select form-select-sm" })
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted mb-1">Estado</label>
                    @{
                        var activoFiltro = ViewBag.Activo as bool?;
                    }
                    <select name="activo" class="form-select form-select-sm">
                        <option value="">Todos</option>
                        @if (activoFiltro == true)
                        {
                            <option value="true" selected="selected">Activo</option>
                        }
                        else
                        {
                            <option value="true">Activo</option>
                        }
                        @if (activoFiltro == false)
                        {
                            <option value="false" selected="selected">Inactivo</option>
                        }
                        else
                        {
                            <option value="false">Inactivo</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-primary flex-grow-1">
                        <i class="fas fa-search"></i> Filtrar
                    </button>
                    <a href="@Url.Action("GestionUsuarios", "Admin")" class="btn btn-sm btn-outline-secondary btn-icon" title="Limpiar filtros">
                        <i class="fas fa-times"></i>
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Usuarios del Sistema</h5>
        <small class="text-muted">@Model.TotalCount resultado(s)</small>
    </div>
    <div class="card-body p-0">
        @if (Model.Items.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover table-clean mb-0">
                    <thead>
                        <tr>
                            @{
                                var sortRouteValues = new System.Web.Routing.RouteValueDictionary(new
                                {
                                    search = ViewBag.Search,
                                    rolId = ViewBag.RolId,
                                    activo = ViewBag.Activo
                                });
                            }
                            <th>
                                @Html.Partial("_SortableHeader", new induccion_refactorization.ViewModels.SortableHeaderViewModel
                                {
                                    Label = "Usuario", SortField = "Nombre", CurrentSortBy = ViewBag.SortBy, CurrentSortDir = ViewBag.SortDir,
                                    Action = "GestionUsuarios", Controller = "Admin", RouteValues = sortRouteValues
                                })
                            </th>
                            <th>
                                @Html.Partial("_SortableHeader", new induccion_refactorization.ViewModels.SortableHeaderViewModel
                                {
                                    Label = "Correo", SortField = "Correo", CurrentSortBy = ViewBag.SortBy, CurrentSortDir = ViewBag.SortDir,
                                    Action = "GestionUsuarios", Controller = "Admin", RouteValues = sortRouteValues
                                })
                            </th>
                            <th>
                                @Html.Partial("_SortableHeader", new induccion_refactorization.ViewModels.SortableHeaderViewModel
                                {
                                    Label = "Rol", SortField = "Rol", CurrentSortBy = ViewBag.SortBy, CurrentSortDir = ViewBag.SortDir,
                                    Action = "GestionUsuarios", Controller = "Admin", RouteValues = sortRouteValues
                                })
                            </th>
                            <th class="text-center">
                                @Html.Partial("_SortableHeader", new induccion_refactorization.ViewModels.SortableHeaderViewModel
                                {
                                    Label = "Estado", SortField = "Estado", CurrentSortBy = ViewBag.SortBy, CurrentSortDir = ViewBag.SortDir,
                                    Action = "GestionUsuarios", Controller = "Admin", RouteValues = sortRouteValues
                                })
                            </th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var usuario in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="icon-badge icon-badge-sm icon-badge-primary">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@usuario.NombreCompleto</div>
                                            <small class="text-muted">@usuario.NombreUsuario</small>
                                        </div>
                                    </div>
                                </td>
                                <td>@usuario.CorreoElectronico</td>
                                <td>
                                    <span class="badge bg-info">@(usuario.Role?.Nombre)</span>
                                </td>
                                <td class="text-center">
                                    @if (usuario.Activo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivo</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a href="@Url.Action("EditUsuario", new { id = usuario.UsuarioID })"
                                       class="btn btn-sm btn-outline-secondary btn-icon"
                                       title="Editar Usuario">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    @using (Html.BeginForm("ToggleActivoUsuario", "Admin", new { id = usuario.UsuarioID }, FormMethod.Post, new { @class = "d-inline" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-sm btn-icon @(usuario.Activo ? "btn-outline-danger" : "btn-outline-success")"
                                                title="@(usuario.Activo ? "Desactivar" : "Reactivar")"
                                                onclick="return confirm('¿Está seguro de @(usuario.Activo ? "desactivar" : "reactivar") este usuario?');">
                                            <i class="fas @(usuario.Activo ? "fa-user-slash" : "fa-user-check")"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @Html.Partial("_Pager", new induccion_refactorization.ViewModels.PagerViewModel
            {
                PageNumber = Model.PageNumber,
                TotalPages = Model.TotalPages,
                PageSize = Model.PageSize,
                Action = "GestionUsuarios",
                Controller = "Admin",
                RouteValues = new System.Web.Routing.RouteValueDictionary(new { search = ViewBag.Search, rolId = ViewBag.RolId, activo = ViewBag.Activo, sortBy = ViewBag.SortBy, sortDir = ViewBag.SortDir })
            })
        }
        else
        {
            <div class="empty-state">
                <div class="icon-badge icon-badge-lg icon-badge-info">
                    <i class="fas fa-users"></i>
                </div>
                <div class="empty-state-title">No se encontraron usuarios</div>
                <p class="mb-0">Intenta ajustar los filtros de búsqueda.</p>
            </div>
        }
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function() {
            setTimeout(function() {
                $('.alert').fadeOut('slow');
            }, 5000);
        });
    </script>
}
