@{
    ViewBag.Title = "Panel de Administración";
}

<div class="mb-4">
    <h2 class="mb-1"><i class="fas fa-cog text-primary"></i> Panel de Administración</h2>
    <p class="text-muted mb-0">Bienvenido, <strong>@ViewBag.NombreCompleto</strong></p>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-md-5">
        <div class="action-card">
            <div class="icon-badge icon-badge-lg icon-badge-primary">
                <i class="fas fa-book"></i>
            </div>
            <h5 class="action-card-title">Gestión de Materias</h5>
            <p class="action-card-text">Crear y editar materias de inducción, unidades y entregables.</p>
            <a href="@Url.Action("Index", "InductionMaintenance")" class="btn btn-primary">
                Ir a Gestión <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>
    </div>

    <div class="col-md-5">
        <div class="action-card">
            <div class="icon-badge icon-badge-lg icon-badge-success">
                <i class="fas fa-user-cog"></i>
            </div>
            <h5 class="action-card-title">Gestión de Usuarios</h5>
            <p class="action-card-text">Administrar cuentas, roles y estado de acceso del sistema.</p>
            <a href="@Url.Action("GestionUsuarios", "Admin")" class="btn btn-success">
                Ir a Gestión <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>
    </div>

    <div class="col-md-5">
        <div class="action-card">
            <div class="icon-badge icon-badge-lg icon-badge-secondary">
                <i class="fas fa-calendar-alt"></i>
            </div>
            <h5 class="action-card-title">Gestión de Periodos</h5>
            <p class="action-card-text">Crear y administrar los periodos disponibles para las materias.</p>
            <a href="@Url.Action("GestionPeriodos", "Admin")" class="btn btn-secondary">
                Ir a Gestión <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>
    </div>

    <div class="col-md-5">
        <div class="action-card">
            <div class="icon-badge icon-badge-lg icon-badge-warning">
                <i class="fas fa-shield-alt"></i>
            </div>
            <h5 class="action-card-title">Permisos por Rol</h5>
            <p class="action-card-text">Consulta qué puede hacer cada rol dentro del sistema.</p>
            <a href="@Url.Action("Permisos", "Admin")" class="btn btn-warning">
                Ver Permisos <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>
    </div>

    <div class="col-md-5">
        <div class="action-card">
            <div class="icon-badge icon-badge-lg icon-badge-info">
                <i class="fas fa-chart-bar"></i>
            </div>
            <h5 class="action-card-title">Reportes</h5>
            <p class="action-card-text">Estadísticas y reportes del sistema de inducción.</p>
            <a href="@Url.Action("Reportes", "Admin")" class="btn btn-info text-white">
                Ver Reportes <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>
    </div>
</div>
